   "source": [
    "# Earthquake Analysis - Jupiter in Kendra/Dusthana"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd
",
    "import matplotlib.pyplot as plt
",
    "
",
    "# Load data
",
    "quake_planets = pd.read_csv("earthquake_planet_data.csv")
",
    "non_quake_planets = pd.read_csv("non_eq_planet_data (1).csv")
",
    "
",
    "# Add label
",
    "quake_planets["EQ_Happened"] = 1
",
    "non_quake_planets["EQ_Happened"] = 0
",
    "
",
    "# Merge
",
    "merged_planets = pd.concat([quake_planets, non_quake_planets], ignore_index=True)
",
    "
",
    "# Filter Jupiter rows
",
    "jupiter_df = merged_planets[merged_planets["Planet"] == "Jupiter:"].copy()
",
    "jupiter_df["House_Clean"] = jupiter_df["House"].astype(str).str.extract(r"(\\d+)")
",
    "jupiter_df = jupiter_df.dropna(subset=["House_Clean"])
",
    "jupiter_df["House_Clean"] = jupiter_df["House_Clean"].astype(int)
",
    "
",
    "# Count occurrences in Kendra/Dusthana
",
    "target_houses = [1, 4, 7, 10, 8, 12]
",
    "quake_counts = jupiter_df[jupiter_df["EQ_Happened"] == 1]["House_Clean"].isin(target_houses).sum()
",
    "quake_total = jupiter_df[jupiter_df["EQ_Happened"] == 1].shape[0]
",
    "
",
    "nonquake_counts = jupiter_df[jupiter_df["EQ_Happened"] == 0]["House_Clean"].isin(target_houses).sum()
",
    "nonquake_total = jupiter_df[jupiter_df["EQ_Happened"] == 0].shape[0]
",
    "
",
    "# Display results
",
    "print(f"Jupiter in Kendra/Dusthana (EQ): {quake_counts} / {quake_total} → {round(quake_counts/quake_total*100, 2)}%")
",
    "print(f"Jupiter in Kendra/Dusthana (Non-EQ): {nonquake_counts} / {nonquake_total} → {round(nonquake_counts/nonquake_total*100, 2)}%")
",
    "
",
    "# Bar chart
",
    "labels = ["Earthquake", "Non-Earthquake"]
",
    "values = [quake_counts / quake_total * 100, nonquake_counts / nonquake_total * 100]
",
    "
",
    "plt.figure(figsize=(6,4))
",
    "plt.bar(labels, values, color=["red", "green"])
",
    "plt.title("% Charts with Jupiter in Kendra/Dusthana")
",
    "plt.ylabel("% of Charts")
",
    "plt.ylim(0, 100)
",
    "plt.grid(axis='y', linestyle='--', alpha=0.7)
",
    "plt.tight_layout()
",
    "plt.show()"
   ]
  }
 ],
